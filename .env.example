# ─────────────────────────────────────────────────────────
# UNICC AI Safety Council — Environment Configuration
# Copy this file to .env and fill in your credentials
# ─────────────────────────────────────────────────────────

# ── LLM Backend ─────────────────────────────────────────
# "anthropic" → use Claude via Anthropic API (recommended for evaluation, no GPU needed)
# "local"     → use Llama 3.2-3B-Instruct locally (requires HuggingFace token + ~6GB RAM)
LLM_BACKEND=anthropic

# Anthropic API key — required when LLM_BACKEND=anthropic
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── HuggingFace (local mode only) ───────────────────────
# Required when LLM_BACKEND=local
# Request Llama 3 access at https://huggingface.co/meta-llama/Llama-3.2-3B-Instruct
HF_TOKEN=hf_your_token_here

# ── Local model override (optional) ─────────────────────
# Defaults to Llama 3.2-3B-Instruct when LLM_BACKEND=local
# BASE_MODEL_ID=meta-llama/Llama-3.2-3B-Instruct

# ── Deliberation Layer ───────────────────────────────────
# BOTH variables must be set to true to enable full LLM deliberation.
#
# UNICC_DELIBERATION=true      → enable the deliberation pipeline (critique + defense rounds)
# UNICC_DELIBERATION=false     → skip deliberation entirely, run sequential pipeline only
UNICC_DELIBERATION=true

# UNICC_DELIBERATION_ACTIVE=true  → actually invoke the LLM for each critique/defense round
#                                    (recommended with Anthropic backend — default: true)
# UNICC_DELIBERATION_ACTIVE=false → stub mode (returns empty critiques/defenses, faster)
#
# ⚠️  BOTH must be true for deliberation to run. Setting only one has no effect.
UNICC_DELIBERATION_ACTIVE=true
